# === Project Syndicate Environment Variables ===

# AI — Required for Genesis Claude API calls (evaluation, spawn decisions, daily reports)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/syndicate
# Path to pg_dump binary (if not in PATH)
PG_DUMP_PATH=pg_dump

# Redis / Memurai — Message bus for The Agora and trade gate
REDIS_URL=redis://localhost:6379

# Exchange (Primary — Kraken)
EXCHANGE_API_KEY=your_kraken_api_key
EXCHANGE_API_SECRET=your_kraken_api_secret

# Exchange (Secondary — Binance, used for global market data)
EXCHANGE_SECONDARY_API_KEY=your_binance_api_key
EXCHANGE_SECONDARY_API_SECRET=your_binance_api_secret

# Email / SMTP — For daily reports and emergency alerts (Gmail recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=your_email@example.com
ALERT_EMAIL_FROM=syndicate@example.com

# Currency & Accounting — Owner is in Canada, accounting in CAD
HOME_CURRENCY=CAD
STARTING_TREASURY=500.0
CURRENCY_CACHE_TTL_SECONDS=300
USD_CAD_FALLBACK_RATE=1.38
USDT_CAD_FALLBACK_RATE=1.38
USDT_CAD_MANUAL_OVERRIDE=0.0
USD_CAD_MANUAL_OVERRIDE=0.0

# Risk Thresholds
CIRCUIT_BREAKER_THRESHOLD=0.75
YELLOW_ALERT_THRESHOLD=0.15
RED_ALERT_THRESHOLD=0.30
PER_AGENT_MAX_POSITION_PCT=0.25
PER_AGENT_MAX_LOSS_PCT=0.50
TRADE_GATE_THRESHOLD=0.05

# Genesis Configuration
GENESIS_CYCLE_INTERVAL_SECONDS=300
WARDEN_CYCLE_INTERVAL_SECONDS=30
MAX_AGENTS=20
DEFAULT_SURVIVAL_CLOCK_DAYS=14
MIN_SPAWN_CAPITAL=20.0
TREASURY_RESERVE_RATIO=0.20
RANDOM_ALLOCATION_PCT=0.10

# Evaluation Weights (must sum to 1.0)
EVAL_WEIGHT_SHARPE=0.40
EVAL_WEIGHT_TRUE_PNL=0.25
EVAL_WEIGHT_THINKING_EFFICIENCY=0.20
EVAL_WEIGHT_CONSISTENCY=0.15

# Prestige Thresholds (evaluations survived)
PRESTIGE_PROVEN_THRESHOLD=3
PRESTIGE_VETERAN_THRESHOLD=10

# Prestige Capital Multipliers
PRESTIGE_PROVEN_MULTIPLIER=1.10
PRESTIGE_VETERAN_MULTIPLIER=1.20
PRESTIGE_ELITE_MULTIPLIER=1.30
PRESTIGE_LEGENDARY_MULTIPLIER=1.50

# Thinking Budgets (daily caps in USD)
GENESIS_DAILY_THINKING_BUDGET=2.00
NEW_AGENT_DAILY_THINKING_BUDGET=0.50

# Phase 3A: Thinking Cycle
SCOUT_CYCLE_INTERVAL=300
STRATEGIST_CYCLE_INTERVAL=900
OPERATOR_ACTIVE_CYCLE_INTERVAL=60
OPERATOR_IDLE_CYCLE_INTERVAL=900
INTERRUPT_COOLDOWN_SECONDS=60
MAX_RETRIES_PER_CYCLE=1
RETRY_TAX_MULTIPLIER=2.0
REFLECTION_EVERY_N_CYCLES=10
SHORT_TERM_MEMORY_SIZE=50
CONTEXT_TOKEN_BUDGET_NORMAL=3000
CONTEXT_TOKEN_BUDGET_SURVIVAL=1500

# API Temperature defaults (per role)
SCOUT_TEMPERATURE=0.7
STRATEGIST_TEMPERATURE=0.5
CRITIC_TEMPERATURE=0.2
OPERATOR_TEMPERATURE=0.2

# Phase 3B: Boot Sequence
GEN1_SURVIVAL_CLOCK_DAYS=21
OPPORTUNITY_TTL_HOURS=6
HEALTH_CHECK_DAY=10
ORIENTATION_TOKEN_BUDGET_MULTIPLIER=1.5

# Phase 3C: Paper Trading
TRADING_MODE=paper
DEFAULT_EXCHANGE=kraken
PRICE_CACHE_TICKER_TTL=10
PRICE_CACHE_ORDERBOOK_TTL=10
STALE_PRICE_THRESHOLD=60
POSITION_MONITOR_INTERVAL=10
LIMIT_ORDER_MONITOR_INTERVAL=10
SANITY_CHECK_INTERVAL=300
EQUITY_SNAPSHOT_INTERVAL=300
DEFAULT_LIMIT_ORDER_EXPIRY_HOURS=24
MIN_SLIPPAGE_PCT=0.0001
SLIPPAGE_NOISE_RANGE=0.2
BOOK_DEPTH_PENALTY_PCT=0.005
CONCENTRATION_WARNING_THRESHOLD=0.40

# Phase 3D: Evaluation Cycle
FIRST_EVAL_LENIENCY=true
PROBATION_GRACE_CYCLES=3
POST_MORTEM_PUBLISH_DELAY_HOURS=6
PORTFOLIO_CONCENTRATION_HARD_LIMIT=0.50
PORTFOLIO_CONCENTRATION_WARNING=0.35
TOP_PERFORMER_BUDGET_INCREASE=0.50
SECOND_PERFORMER_BUDGET_INCREASE=0.25
PROBATION_BUDGET_DECREASE=0.25
NORM_OPERATOR_SHARPE_RANGE=[-1.0, 3.0]
NORM_OPERATOR_PNL_RANGE=[-20.0, 30.0]
NORM_OPERATOR_EFFICIENCY_RANGE=[0.0, 5.0]
NORM_SCOUT_CONVERSION_RANGE=[0.0, 0.50]
NORM_SCOUT_PROFITABILITY_RANGE=[-5.0, 10.0]
NORM_STRATEGIST_APPROVAL_RANGE=[0.0, 0.80]
NORM_CRITIC_REJECTION_RANGE=[-1.0, 1.0]
NORM_CRITIC_THROUGHPUT_RANGE=[0.0, 3.0]
ATTRIBUTION_SCOUT_SHARE=0.25
ATTRIBUTION_STRATEGIST_SHARE=0.25
ATTRIBUTION_CRITIC_SHARE=0.50
CRITIC_RUBBER_STAMP_THRESHOLD=0.90
CRITIC_RUBBER_STAMP_PENALTY=0.50

# Phase 3E: Personality Through Experience
TEMPERATURE_DRIFT_AMOUNT=0.05
TEMPERATURE_SIGNAL_THRESHOLD=0.2
TEMPERATURE_BOUNDS_SCOUT=[0.3, 0.9]
TEMPERATURE_BOUNDS_STRATEGIST=[0.2, 0.7]
TEMPERATURE_BOUNDS_CRITIC=[0.1, 0.4]
TEMPERATURE_BOUNDS_OPERATOR=[0.1, 0.4]
TRUST_DECAY_FACTOR=0.95
TRUST_PRIOR=0.5
TRUST_MIN_INTERACTIONS_TO_SHOW=2
REFLECTION_LIBRARY_COOLDOWN=5
DIVERGENCE_LOW_THRESHOLD=0.15
DIVERGENCE_MIN_COMPARABLE_METRICS=3
PROFILE_MIN_POSITIONS=10
PROFILE_MIN_CYCLES=20
PROFILE_MIN_CYCLE_DAYS=3
PROFILE_MIN_ACTIONS=15
PROFILE_MIN_PIPELINE_OUTCOMES=5
PROFILE_MIN_EVALUATIONS=2
PROFILE_MIN_LOSSES=3
IDENTITY_NEW_THRESHOLD=30
IDENTITY_ESTABLISHED_THRESHOLD=100
PERSONALITY_DRIFT_TIER_THRESHOLD=2

# Phase 3F: Reproduction & Dynasties
REPRODUCTION_COOLDOWN_EVALS=3
REPRODUCTION_MIN_PRESTIGE=Veteran
DYNASTY_CONCENTRATION_HARD_LIMIT=0.40
DYNASTY_CONCENTRATION_WARNING=0.25
MEMORY_INHERITANCE_DISCOUNT=0.75
MEMORY_AGE_DECAY_FACTOR=0.95
MEMORY_AGE_DECAY_START_DAYS=30
MEMORY_CONFIDENCE_FLOOR=0.10
TRUST_INHERITANCE_FACTOR=0.50
TEMPERATURE_MUTATION_RANGE=0.03
MAX_REPRODUCTIONS_PER_CYCLE=1
OFFSPRING_SURVIVAL_CLOCK_DAYS=14

# Phase 3.5: Cost Optimization
# Model routing — Haiku default, Sonnet for high-stakes
MODEL_DEFAULT=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-20250514
MODEL_ROUTING_ENABLED=true

# Pricing per million tokens (update if Anthropic changes pricing)
HAIKU_INPUT_PRICE=1.00
HAIKU_OUTPUT_PRICE=5.00
SONNET_INPUT_PRICE=3.00
SONNET_OUTPUT_PRICE=15.00

# Prompt caching — 90% input token savings on repeated system prompts
PROMPT_CACHING_ENABLED=true

# Adaptive cycle frequency — stretch/compress based on market regime
ADAPTIVE_FREQUENCY_ENABLED=true
MIN_CYCLE_INTERVAL_SECONDS=30

# Context diet — smaller context for Haiku, truncate old Agora messages
HAIKU_CONTEXT_BUDGET_MULTIPLIER=0.70
AGORA_MESSAGE_TRUNCATE_AFTER_CYCLES=5
AGORA_MESSAGE_TRUNCATE_LENGTH=100

# Batch API — OFF by default, enable in Phase 4
BATCH_ENABLED=false
BATCH_POLL_INTERVAL_SECONDS=30
BATCH_TIMEOUT_SECONDS=3600

# Phase 8B: Survival Instinct
STRATEGIC_REVIEW_CYCLE_INTERVAL=50
PRESSURE_EVAL_IMMINENT_DAYS=5
PRESSURE_EVAL_CRITICAL_DAYS=3
DEATH_FEED_LOOKBACK_DAYS=7
SIP_MAX_PER_EVALUATION_PERIOD=1
SIP_THINKING_TAX_MULTIPLIER=2.0
INTEL_SETTLEMENT_WINDOW_HOURS=48
INTEL_PRICE_CHANGE_THRESHOLD_PCT=0.5
ALLIANCE_TRUST_BONUS=0.1
REPUTATION_EVALUATION_WEIGHT=0.10
DEATH_LAST_WORDS_ENABLED=true
DEATH_LAST_WORDS_MODEL=claude-haiku-4-5-20251001

# Phase 8C: Code Sandbox
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEMORY_LIMIT_MB=50
SANDBOX_OUTPUT_LIMIT_BYTES=10240
SANDBOX_MAX_SCRIPT_LENGTH=5000
SANDBOX_BASE_COST_USD=0.001
SANDBOX_TIME_RATE_USD_PER_MS=0.0001
SANDBOX_MAX_TOOLS_PER_CYCLE=3
SANDBOX_MAX_PRE_COMPUTE_TOOLS=3
DAILY_SANDBOX_CAP_USD=0.50

# Phase 8C: Strategy Genome
GENOME_MUTATION_RATE=0.15
GENOME_MUTATION_STRENGTH=0.10
GENOME_STRUCTURAL_MUTATION_RATE=0.05
GENOME_WARMSTART_MUTATION_RATE=0.40
GENOME_WARMSTART_MUTATION_STRENGTH=0.20
GENOME_MAX_MODIFICATIONS_PER_EVAL=2
GENOME_FITNESS_AGE_BONUS=0.1
GENOME_DIVERSITY_LOW_THRESHOLD=0.3
TOOL_INHERITANCE_STAT_DISCOUNT=0.50
TOOL_OUTCOME_CORRELATION_LOOKBACK_CYCLES=3

# Logging
LOG_LEVEL=INFO

# Solana (Phase 5 — not yet used)
SOLANA_WALLET_PRIVATE_KEY=your_solana_private_key

# Twitter/X (Phase 5 — not yet used)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
