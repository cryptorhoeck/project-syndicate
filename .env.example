# === Project Syndicate Environment Variables ===

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/syndicate

# Redis / Memurai
REDIS_URL=redis://localhost:6379

# Exchange (Primary)
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_API_SECRET=your_exchange_api_secret

# Exchange (Secondary)
EXCHANGE_SECONDARY_API_KEY=your_secondary_exchange_api_key
EXCHANGE_SECONDARY_API_SECRET=your_secondary_exchange_api_secret

# Alerts
ALERT_EMAIL_TO=your_email@example.com
ALERT_EMAIL_FROM=syndicate@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Solana (Phase 5)
SOLANA_WALLET_PRIVATE_KEY=your_solana_private_key

# Twitter/X (Phase 5)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# System Thresholds
CIRCUIT_BREAKER_THRESHOLD=0.75
YELLOW_ALERT_THRESHOLD=0.15
RED_ALERT_THRESHOLD=0.30
DEFAULT_SURVIVAL_CLOCK_DAYS=14
MAX_AGENTS=20
LOG_LEVEL=INFO
