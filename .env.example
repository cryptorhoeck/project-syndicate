# === Project Syndicate Environment Variables ===

# AI — Required for Genesis Claude API calls (evaluation, spawn decisions, daily reports)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/syndicate
# Path to pg_dump binary (if not in PATH)
PG_DUMP_PATH=pg_dump

# Redis / Memurai — Message bus for The Agora and trade gate
REDIS_URL=redis://localhost:6379

# Exchange (Primary — Kraken)
EXCHANGE_API_KEY=your_kraken_api_key
EXCHANGE_API_SECRET=your_kraken_api_secret

# Exchange (Secondary — Binance, used for global market data)
EXCHANGE_SECONDARY_API_KEY=your_binance_api_key
EXCHANGE_SECONDARY_API_SECRET=your_binance_api_secret

# Email / SMTP — For daily reports and emergency alerts (Gmail recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=your_email@example.com
ALERT_EMAIL_FROM=syndicate@example.com

# Risk Thresholds
CIRCUIT_BREAKER_THRESHOLD=0.75
YELLOW_ALERT_THRESHOLD=0.15
RED_ALERT_THRESHOLD=0.30
PER_AGENT_MAX_POSITION_PCT=0.25
PER_AGENT_MAX_LOSS_PCT=0.50
TRADE_GATE_THRESHOLD=0.05

# Genesis Configuration
GENESIS_CYCLE_INTERVAL_SECONDS=300
WARDEN_CYCLE_INTERVAL_SECONDS=30
MAX_AGENTS=20
DEFAULT_SURVIVAL_CLOCK_DAYS=14
MIN_SPAWN_CAPITAL=20.0
TREASURY_RESERVE_RATIO=0.20
RANDOM_ALLOCATION_PCT=0.10

# Evaluation Weights (must sum to 1.0)
EVAL_WEIGHT_SHARPE=0.40
EVAL_WEIGHT_TRUE_PNL=0.25
EVAL_WEIGHT_THINKING_EFFICIENCY=0.20
EVAL_WEIGHT_CONSISTENCY=0.15

# Prestige Thresholds (evaluations survived)
PRESTIGE_PROVEN_THRESHOLD=3
PRESTIGE_VETERAN_THRESHOLD=10

# Prestige Capital Multipliers
PRESTIGE_PROVEN_MULTIPLIER=1.10
PRESTIGE_VETERAN_MULTIPLIER=1.20
PRESTIGE_ELITE_MULTIPLIER=1.30
PRESTIGE_LEGENDARY_MULTIPLIER=1.50

# Thinking Budgets (daily caps in USD)
GENESIS_DAILY_THINKING_BUDGET=2.00
NEW_AGENT_DAILY_THINKING_BUDGET=0.50

# Logging
LOG_LEVEL=INFO

# Solana (Phase 5 — not yet used)
SOLANA_WALLET_PRIVATE_KEY=your_solana_private_key

# Twitter/X (Phase 5 — not yet used)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
